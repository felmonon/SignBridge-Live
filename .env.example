GEMINI_API_KEY=your_google_ai_studio_key
OPENAI_API_KEY=your_openai_key

# Optional
APP_NAME=SignBridge Live
HOST=127.0.0.1
PORT=8000
# FRONTEND_DIST_DIR=/absolute/path/to/frontend/dist
GEMINI_MODEL=gemini-2.5-flash
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral
CLIP_SECONDS=3.0
SIGN_LANGUAGE_HINT=ASL
SESSION_CONTEXT_LIMIT=6
SESSION_TTL_SECONDS=1800

# Optional: production-safe session persistence for serverless deployments
# Create an Upstash Redis database and set both values to enable shared session state.
# Vercel Marketplace integrations often expose the same values as KV_REST_API_URL and
# KV_REST_API_TOKEN; the backend accepts either naming scheme.
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token
